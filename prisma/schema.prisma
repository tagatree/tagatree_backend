generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cycle {
  id           String   @id @default(cuid())
  name         String
  cycleEndDate DateTime
  capacity     Int
  paidCount    Int
  active       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
